{
  "name": "vibe-forecast",
  "version": "3.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:prod": "dotenv -e .env.production next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "cd simulator && playwright test",
    "test:e2e:prod": "cd simulator && TEST_ENV=production BASE_URL=https://vibe-forecast.vercel.app/ npx playwright test --config=playwright.config.ts",
    "test:ui": "cd simulator && playwright test --ui",
    "test:headed": "cd simulator && playwright test --headed",
    "test:debug": "cd simulator && playwright test --debug",
    "test:ci": "cd simulator && playwright test",
    "test:report": "cd simulator && playwright show-report $(ls -t result/*/html-report | head -1)",
    "test:auth": "cd simulator && playwright test auth.test.ts",
    "test:prediction": "cd simulator && playwright test prediction.test.ts",
    "test:navigation": "cd simulator && playwright test navigation.test.ts",
    "test:stats": "cd simulator && playwright test stats.test.ts",
    "test:leaderboard": "cd simulator && playwright test leaderboard.test.ts",
    "test:assets": "cd simulator && playwright test assets.test.ts",
    "test:edge": "cd simulator && playwright test edge-cases.test.ts",
    "test:sim": "tsx simulator/test.ts",
    "test:sim:prod": "dotenv -e simulator/.env.production tsx simulator/test.ts",
    "test:unit": "vitest run",
    "test:vats": "tsx src/test/vats-runner.ts",
    "test:qa": "cd simulator && BASE_URL=http://localhost:3000 npx playwright test e2e/qa-full.test.ts --reporter=list",
    "test:load": "cd simulator && BASE_URL=http://localhost:3000 LOAD_USERS=10 npx playwright test e2e/load.test.ts --reporter=list --workers=4",
    "test:all": "bash run-tests.sh"
  },
  "dependencies": {
    "@next/third-parties": "^16.1.6",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.93.3",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.31.0",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "openai": "^6.22.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/ui": "^4.0.18",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jsdom": "^28.0.0",
    "playwright": "^1.58.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}