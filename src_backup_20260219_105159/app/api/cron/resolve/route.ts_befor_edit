import { createClient } from '@supabase/supabase-js';
import { NextRequest, NextResponse } from 'next/server';

// 1. Setup Supabase Client (Service Role needed for RPC)
const supabase = createClient(
    process.env.NEXT_PUBLIC_SUPABASE_URL!,
    process.env.SUPABASE_SERVICE_ROLE_KEY! // Use Service Role Key for CRON
);

// Helper for rate limiting
const sleep = (ms: number) => new Promise((resolve) => setTimeout(resolve, ms));

export async function GET(req: NextRequest) {
    // Check for Cron Secret (Optional but recommended for security)
    // const authHeader = req.headers.get('authorization');
    // if (authHeader !== `Bearer ${process.env.CRON_SECRET}`) {
    //   return new Response('Unauthorized', { status: 401 });
    // }

    try {
        const now = Date.now();

        // 2. Fetch Pending Predictions
        // We only need basic info to group them
        const { data: predictions, error: fetchError } = await supabase
            .from('predictions')
            .select('id, asset_symbol, timeframe, created_at, entry_price, direction, target_percent, user_id, bet_amount, candle_close_at')
            .eq('status', 'pending');

        if (fetchError) throw fetchError;

        console.log(`[Resolution] Found ${predictions?.length || 0} pending predictions.`);

        if (!predictions || predictions.length === 0) {
            return NextResponse.json({ message: 'No pending predictions' });
        }

        // 3. Group by Candle (Symbol + Timeframe + OpenTime)
        const candleGroups: Record<string, {
            symbol: string;
            tf: string;
            openTime: number;
            closeTime: number;
            preds: any[];
        }> = {};

        for (const pred of predictions) {
            // Use DB source of truth for close time
            const closeTime = new Date(pred.candle_close_at).getTime();

            // Calculate duration to derive Open Time
            // (We could store open_time too, but calculating backward from close is safe if duration is fixed)
            let duration = 0;
            const tfVal = parseInt(pred.timeframe);
            if (pred.timeframe.endsWith('m')) duration = tfVal * 60 * 1000;
            else if (pred.timeframe.endsWith('h')) duration = tfVal * 60 * 60 * 1000;
            else if (pred.timeframe.endsWith('d')) duration = tfVal * 24 * 60 * 60 * 1000;

            const openTime = closeTime - duration;

            // Check if candle is closed (plus buffer)
            const isReady = now > closeTime + 10000; // 10s buffer
            console.log(`[Resolution] Pred ${pred.id} (${pred.timeframe}): CloseTime ${new Date(closeTime).toISOString()} vs Now ${new Date(now).toISOString()} -> Ready? ${isReady}`);

            if (isReady) {
                const key = `${pred.asset_symbol}-${pred.timeframe}-${openTime}`;
                if (!candleGroups[key]) {
                    candleGroups[key] = {
                        symbol: pred.asset_symbol,
                        tf: pred.timeframe,
                        openTime,
                        closeTime,
                        preds: []
                    };
                }
                candleGroups[key].preds.push(pred);
            }
        }

        const groupKeys = Object.keys(candleGroups);
        if (groupKeys.length === 0) {
            return NextResponse.json({ message: 'No candles completed yet' });
        }

        const results = {
            resolved: 0,
            errors: 0,
            details: [] as any[]
        };

        // 4. Process Each Group
        for (const key of groupKeys) {
            const group = candleGroups[key];
            let closePrice: number | null = null;
            let errorMsg: string | null = null;

            // Rate Limiting: Sleep 200ms between calls
            await sleep(200);

            try {
                // Calculate Reference Price (Average Entry Price of the group)
                // This is used for the Ultimate Fail-Safe if all APIs fail.
                const totalEntry = group.preds.reduce((sum: number, p: any) => sum + (p.entry_price || 0), 0);
                const avgEntry = totalEntry / (group.preds.length || 1);

                // Fetch Price
                closePrice = await fetchClosePrice(group.symbol, group.tf, group.openTime, avgEntry);
            } catch (e: any) {
                console.error(`Failed to fetch price for ${key}:`, e);
                errorMsg = e.message;
            }

            // If we have a price, resolve all predictions in this group
            if (closePrice !== null) {
                // Calculate Crowd Multiplier for this candle
                const totalPreds = group.preds.length;
                let upCount = 0;
                let downCount = 0;

                group.preds.forEach((p: any) => {
                    if (p.direction === 'UP') upCount++;
                    else if (p.direction === 'DOWN') downCount++;
                });

                // Crowd Factor Calculation
                // Rule: Multiplier = 1 - (MajorityRatio - 0.5)
                // If 50:50 -> 1.0
                // If 100:0 -> 0.5

                // Determine direction outcome (price vs entry) implies direction? 
                // No, Crowd Multiplier depends on what the MAJORITY bet on, regardless of outcome.
                // Wait, if Majority bet WRONG, do winners (Minority) get higher reward?
                // The user said: "Crowd Factor Multiplier = 1 - (Majority Side Ratio - 0.5)"
                // This implies if 80% bet UP, and UP wins, they get reduced reward (0.7).
                // If 80% bet UP, and DOWN wins, the 20% (Minority) get... ?
                // Usually Minority gets BOOST. 
                // User formula: "Crowd Factor Multiplier = 1 - (Majority Side Ratio - 0.5)"
                // This formula reduces reward if YOU are in the majority.

                // So I need to calculate multiplier specific to the DIRECTION.

                const upRatio = totalPreds > 0 ? upCount / totalPreds : 0.5;
                const downRatio = totalPreds > 0 ? downCount / totalPreds : 0.5;

                const upCrowdMult = upRatio > 0.5 ? (1 - (upRatio - 0.5)) : 1.0 + (0.5 - upRatio);
                // Wait, if Minority (Ratio < 0.5), do they get > 1.0? 
                // User didn't explicitly say "Boost Minority", but "Reduce Majority".
                // "소수 의견이 맞으면 큰 보상" -> Yes, Boost.
                // Symmetric formula: 
                // If ratio = 0.8 (Majority), Mult = 1 - (0.8 - 0.5) = 0.7
                // If ratio = 0.2 (Minority), Mult = 1 + (0.5 - 0.2) = 1.3 ?
                // Let's stick to the User's EXACT formula for Majority, and symmetric boost for Minority?
                // Actually, standard parimutuel is: Pool / Winners.
                // User formula is "Damped Parimutuel".

                // Let's implement:
                // If UP Wins: Mult = 1 + (0.5 - upRatio)  (e.g., if upRatio 0.8 -> 0.7x. If upRatio 0.2 -> 1.3x)
                // If DOWN Wins: Mult = 1 + (0.5 - downRatio)

                // Let's calculate the specific multiplier for each prediction based on its direction.

                for (const pred of group.preds) {
                    // Logic:
                    // If pred.direction == 'UP', ratio = upRatio.
                    // Mult = 1.0 + (0.5 - ratio).
                    // check: 0.8 -> 1 + (0.5 - 0.8) = 0.7 (Correct)
                    // check: 0.2 -> 1 + (0.5 - 0.2) = 1.3 (Correct)
                    // check: 0.5 -> 1 + 0 = 1.0 (Correct)

                    const mySideRatio = pred.direction === 'UP' ? upRatio : downRatio;
                    // Clamp to handle edge cases (though math holds for 0..1)
                    // limit min/max? User didn't say, but 100% majority -> 0.5x. 0% majority -> 1.5x.
                    // Seems safe.

                    const crowdMult = 1.0 + (0.5 - mySideRatio);

                    // Call RPC with Retry
                    let success = false;
                    let lastError = '';

                    for (let attempt = 0; attempt < 3; attempt++) {
                        const { data, error } = await supabase.rpc('resolve_prediction_advanced', {
                            p_id: pred.id,
                            p_close_price: closePrice,
                            p_crowd_multiplier: crowdMult
                        });

                        if (!error && data && data.success) {
                            success = true;
                            // console.log(`RPC Result for ${pred.id}:`, data);
                            break;
                        }

                        lastError = error ? error.message : (data?.error || 'Unknown RPC error');
                        await sleep(100 * (attempt + 1)); // Exponential backoff
                    }

                    if (success) {
                        results.resolved++;
                        results.details.push({ id: pred.id, status: 'resolved', price: closePrice });
                        console.log(`Successfully resolved prediction ${pred.id} (CrowdMult: ${crowdMult.toFixed(2)})`);

                    } else {
                        results.errors++;
                        results.details.push({ id: pred.id, status: 'error', error: lastError });
                        console.error(`RPC Failed for ${pred.id}: ${lastError}`);
                    }
                }
            } else {
                // If price fetch failed, log errors for all preds in group
                for (const pred of group.preds) {
                    results.errors++;
                    results.details.push({ id: pred.id, status: 'error', error: errorMsg || 'Price fetch failed' });
                }
            }
        }

        return NextResponse.json({ success: true, ...results });

    } catch (err: any) {
        console.error('Cron job error:', err);
        return NextResponse.json({ success: false, error: err.message }, { status: 500 });
    }
}

// Helper: Calculate Candle Window
function getCandleWindow(timestamp: number, timeframe: string) {
    let duration = 15 * 60 * 1000; // default 15m
    const val = parseInt(timeframe);
    const unit = timeframe.slice(-1); // m, h, d

    if (unit === 'm') duration = val * 60 * 1000;
    else if (unit === 'h') duration = val * 60 * 60 * 1000;
    else if (unit === 'd') duration = val * 24 * 60 * 60 * 1000;

    const openTime = Math.floor(timestamp / duration) * duration; // Start of candle
    const closeTime = openTime + duration; // End of candle
    return { openTime, closeTime };
}

// Helper: Fetch Price (Binance or Mock)
async function fetchClosePrice(symbol: string, timeframe: string, openTime: number, referencePrice: number): Promise<number> {
/*
   이 블록은 거래소 응답 시간이
   서로 다른 문제를 해결하기 위한 코드
*/
    const isSameCandle = (exchangeOpenTime: number, targetOpenTime: number, timeframeMs: number) => {
    return Math.abs(exchangeOpenTime - targetOpenTime) < timeframeMs;
    };

    const tfMsMap: Record<string, number> = {
    '1m': 60_000,
    '5m': 300_000,
    '15m': 900_000,
    '1h': 3_600_000,
    '4h': 14_400_000,
    '1d': 86_400_000
    };

    const tfMs = tfMsMap[timeframe] || 900_000;

    const cleanSymbol = symbol.replace('/', '').toUpperCase();
    // 1. Crypto (Binance)
    const cryptoPairs = ['BTCUSDT', 'ETHUSDT', 'SOLUSDT', 'DOGEUSDT', 'XRPUSDT', 'BNBUSDT'];
    // Basic check. In production, maintain a list or try API and look for "Invalid Symbol"

    // 0. Helper for Timeout
    const fetchWithTimeout = async (url: string, timeout = 3000) => { // Increased to 3000ms
        const controller = new AbortController();
        const id = setTimeout(() => controller.abort(), timeout);
        try {
            const res = await fetch(url, { cache: 'no-store', signal: controller.signal });
            clearTimeout(id);
            return res;
        } catch (e) {
            clearTimeout(id);
            throw e;
        }
    };

    if (cryptoPairs.includes(cleanSymbol) || cleanSymbol.endsWith('USDT')) {
        // Fallback Logic: MEXC -> Bybit -> KuCoin -> Vision -> Binance Main -> Yahoo -> Mock
        // We MUST find the candle at 'openTime'.

        // 1. Try MEXC (Public & Fast)
        try {
            const url = `https://api.mexc.com/api/v3/klines?symbol=${cleanSymbol}&interval=${timeframe}&startTime=${openTime}&limit=1`;
            const res = await fetchWithTimeout(url);
            if (res.ok) {
                const data = await res.json();
